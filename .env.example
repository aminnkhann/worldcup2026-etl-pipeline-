# football-data.org
FOOTBALL_API_KEY=your_football_data_api_key_here
FOOTBALL_BASE_URL=https://api.football-data.org/v4
WC_CODE=WC
FOOTBALL_DATA_SEASON=2026
REQUEST_DELAY=6
SCORERS_LIMIT=1000
FETCH_MATCH_DETAILS=true
STORE_RAW_RESPONSES=true
RAW_DATA_DIR=data/raw

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=worldcup2026
DB_USER=worldcup
DB_PASSWORD=your_password_here

# Optional: only for integration tests against an isolated test schema
RUN_DB_TESTS=0
